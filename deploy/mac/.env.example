# Copy this file to ~/.badminton-hub.env and fill in real values.
# Loaded by the app runtime, deploy script, and backup script.

NODE_ENV=production
PORT=5000
APP_URL=http://localhost:8080

DATABASE_URL=postgresql://app_user:change_me@127.0.0.1:5432/badmintonhub

# Used by backup script
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=app_user
PGPASSWORD=change_me
PGDATABASE=badmintonhub

SESSION_SECRET=change_me_to_a_long_random_string

# Optional integrations - set if used by your app
GMAIL_APP_PASSWORD=
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=
