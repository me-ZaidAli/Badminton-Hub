# Copy this file to .env at the project root (next to docker-compose.yml).
# NEVER commit .env to git.

NODE_ENV=production
PORT=5000

# ── PostgreSQL credentials ─────────────────────────────────────────────────
# Used by the postgres container to create the database on first run,
# AND by the app container to connect. Keep them in sync.
PGUSER=app_user
PGPASSWORD=change_me
PGDATABASE=badmintonhub

# Hostname MUST be "postgres" — that is the Docker Compose service name.
DATABASE_URL=postgresql://app_user:change_me@postgres:5432/badmintonhub

# Set to "false" for local Docker postgres (no SSL).
# Set to "true" on Railway or other managed providers that require SSL.
DATABASE_SSL=false

# Set to "true" only when serving over HTTPS. Must be false for plain HTTP.
COOKIE_SECURE=false

# ── App ────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:8080

# Your domain name — required for HTTPS/TLS setup (ssl-setup.sh)
# Must be a real domain with DNS pointing to this machine's public IP.
DOMAIN=badmintonhub.uk
LETSENCRYPT_EMAIL=zaid.ali5430@gmail.com

# Generate with: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_long_random_string

# ── Optional integrations ──────────────────────────────────────────────────
GMAIL_APP_PASSWORD=
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=
