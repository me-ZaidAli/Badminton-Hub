# Copy this file on VM to /etc/badminton-hub.env and fill real values.
# Used by app runtime and backup service.

NODE_ENV=production
PORT=5000
APP_URL=https://your-domain.com

DATABASE_URL=postgresql://app_user:change_me@127.0.0.1:5432/badmintonhub

SESSION_SECRET=change_me

# Optional integrations - set if used by your app
GMAIL_APP_PASSWORD=
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=
